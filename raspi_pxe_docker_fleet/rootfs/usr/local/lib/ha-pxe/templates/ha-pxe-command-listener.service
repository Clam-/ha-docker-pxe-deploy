[Unit]
Description=Home Assistant PXE remote command listener
Wants=network-online.target
After=network-online.target NetworkManager-wait-online.service
ConditionPathExists=/etc/ha-pxe/bootstrap.env
ConditionPathExists=/var/lib/ha-pxe/firstboot.done

[Service]
Type=simple
ExecStart=/usr/local/sbin/ha-pxe-command-listener
Restart=always
RestartSec=15
StandardInput=null
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
