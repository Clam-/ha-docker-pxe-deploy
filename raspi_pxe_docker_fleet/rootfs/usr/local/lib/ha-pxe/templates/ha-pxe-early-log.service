[Unit]
Description=Home Assistant PXE early boot diagnostics
Wants=network.target
Wants=ha-pxe-firstboot.service
After=network.target
Before=ha-pxe-firstboot.service
ConditionPathExists=/etc/ha-pxe/bootstrap.env
ConditionPathExists=!/var/lib/ha-pxe/firstboot.done

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/ha-pxe-early-log
StandardInput=null
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
