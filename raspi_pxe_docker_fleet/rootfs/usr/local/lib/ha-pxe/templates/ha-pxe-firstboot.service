[Unit]
Description=Home Assistant PXE client first boot provisioning
Wants=network-online.target
After=network-online.target cloud-final.service ha-pxe-early-log.service
ConditionPathExists=/etc/ha-pxe/bootstrap.env
ConditionPathExists=!/var/lib/ha-pxe/firstboot.done

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/ha-pxe-firstboot
RemainAfterExit=yes
StandardInput=null
StandardOutput=journal
StandardError=journal
